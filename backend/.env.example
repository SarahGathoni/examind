DATABASE_URL=postgresql://examind:examind123@localhost:5432/examind
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
UPLOADS_DIR=./uploads
REPORTS_DIR=./reports

# Email (SMTP) — leave SMTP_HOST blank to disable email and use manual link sharing
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@examind.io
SMTP_USE_TLS=true

# Public URL of the frontend (used in invite emails and links)
FRONTEND_URL=http://localhost:3000

# How long invite links stay valid
INVITE_EXPIRE_HOURS=72
